# Panel Control - Configuración de Entorno
# Copia este archivo a .env y ajusta los valores

# Base de Datos
DATABASE_URL=postgresql://panel_user:panel_password_123@localhost/panel_db

# Panel
PANEL_PORT=8001
PANEL_HOST=127.0.0.1
PANEL_NAME="Tu Panel"
PANEL_VERSION=1.0.0

# Debug
DEBUG=False
LOG_LEVEL=INFO

# Seguridad (cambiar en producción)
SECRET_KEY=tu-clave-secreta-super-larga-aqui
API_TOKEN=tu-token-api-aqui

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@tu-dominio.com
CERTBOT_PATH=/etc/letsencrypt/

# Paths
BASE_DIR=/opt/panel
SCRIPTS_DIR=/opt/panel/scripts
LOGS_DIR=/opt/panel/logs
DATA_DIR=/opt/panel/data

# Sistema
WEBSERVER=nginx
PHP_VERSIONS=8.2
DEFAULT_PHP=8.2

# Administrador de archivos integrado
FILE_MANAGER_ENABLED=true
FILE_MANAGER_MAX_UPLOAD_MB=100
FILE_MANAGER_MAX_TEXT_FILE_MB=2

# Hostname (se obtiene automáticamente)
SERVER_HOSTNAME=servidor.ejemplo.com
